<% layout('layouts/boilerplate') %>

    <div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 mt-4">
        <% for(let listing of allListings) { %>
            <div class="col mb-4">
                <a href="/listings/<%= listing._id %>" class="text-decoration-none">
                    <div class="card listing-card glass-card h-100">
                        <img src="<%= listing.image.url %>" class="card-img-top" alt="<%= listing.title %>"
                            style="height: 20rem; object-fit: cover;">
                        <div class="card-body container">
                            <h5 class="card-title">
                                <%= listing.title %>
                            </h5>
                            <p class="card-text">
                                <%= listing.location %>, <%= listing.country %>
                            </p>
                            <p class="price-text mt-2">&#8377; <%= listing.price.toLocaleString("en-IN") %> / night</p>
                        </div>
                    </div>
                </a>
            </div>
            <% } %>
    </div>